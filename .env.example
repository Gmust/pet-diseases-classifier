GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Optional for local development. If unset, /predict auth is disabled.
API_KEY=your_secret_api_key_here

# Path to the fine-tuned transformer model directory (produced by app/ml/train.py)
MODEL_PATH=models/transformer_model

# Confidence below this threshold triggers a "seek vet advice" warning
LOW_CONFIDENCE_THRESHOLD=0.65
